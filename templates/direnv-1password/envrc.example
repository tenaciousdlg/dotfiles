# Copy to <project>/.envrc, adjust the values/op refs, then run `direnv allow`.
# Replaces manually re-pasting TF_VAR_* exports (and secrets) into every shell —
# direnv loads this automatically on `cd` into the project, and unloads on `cd` out.

export TF_VAR_user="${USER}@goteleport.com"
export TF_VAR_proxy_address="presales.teleportdemo.com"
export TF_VAR_teleport_version="$(curl -s https://updates.releases.teleport.dev/v1/stable/cloud/version | sed 's/v//')"
export TF_VAR_domain_name="teleportdemo.com"

# Secrets: pulled from 1Password at directory-enter time, never written to disk
# or shell history in plaintext. Create the items once with `op item create`,
# then reference them here by vault/item/field.
export TF_VAR_okta_api_token="$(op read 'op://Demo Environments/okta-integrator/api-token')"
export TF_VAR_okta_metadata_url="$(op read 'op://Demo Environments/okta-integrator/metadata-url')"
export TF_VAR_teleport_scim_client_id="$(op read 'op://Demo Environments/teleport-scim/client-id')"
export TF_VAR_teleport_scim_client_secret="$(op read 'op://Demo Environments/teleport-scim/client-secret')"
export TF_VAR_slack_bot_token="$(op read 'op://Demo Environments/slack-bot/token')"
export TF_VAR_slack_channel_id="$(op read 'op://Demo Environments/slack-bot/channel-id')"
